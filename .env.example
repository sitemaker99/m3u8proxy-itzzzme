# Port to listen on (default: 3000)
PORT=3000

# Comma-separated allowed origins, or * for all (default: *)
# Restrict in production to your frontend domain
# e.g. ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=*

# AnimePahe base URL — used as referer for kwik requests
ANIMEPAHE_BASE=https://animepahe.ru
